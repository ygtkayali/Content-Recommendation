# ── Python ──
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
*.so
venv/
.venv/
*.egg

# ── Environment / secrets ──
.env
.env.*
!.env.example

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── Data (large / sensitive – not for git) ──
data/raw/*.csv
data/raw/*.json
data/processed/*.parquet
data/eval/
data/features/
data/snapshots/
data/staging/

# ── ML artifacts that are too large for git ──
# (embeddings + CSV metadata ARE committed for Docker build)
ml/artifacts/*/embedding_similarity.npy
ml/artifacts/*/*.parquet

# ── Frontend ──
frontend/node_modules/
frontend/.next/
frontend/out/

# ── OS ──
.DS_Store
Thumbs.db
