# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
.vscode/
.idea/

# =========================
# Python (backend + ML)
# =========================
**/__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml

# Virtual environments
.venv/
venv/
env/

# =========================
# Backend
# =========================
backend/.env
backend/.env.*
backend/.python-version

# =========================
# Frontend (Next.js)
# =========================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/coverage/
frontend/.env*
!frontend/.env.example
frontend/*.tsbuildinfo
frontend/next-env.d.ts
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Data & ML artifacts
# Keep docs/readmes trackable while ignoring heavy/generated files
# =========================
# Data directories with large or generated content
data/eval/**
data/features/**
data/processed/**
data/snapshots/**
data/staging/**

# If raw datasets are large/private, keep them ignored by default
# (already tracked files will remain tracked)
data/raw/**
!data/raw/README.md
!data/raw/dataset-links.md

# ML outputs
ml/artifacts/**
ml/experiments/.ipynb_checkpoints/

# Optional local experiment outputs
ml/**/*.joblib
ml/**/*.pkl
ml/**/*.npy
ml/**/*.npz
ml/**/*.parquet
