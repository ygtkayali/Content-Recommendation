# ── Docker ignore ────────────────────────────
# Keep the build context small: only ship what
# the Dockerfile COPYs.

# Version control
.git
.gitignore

# Frontend (not part of backend container)
frontend/

# Documentation
docs/
*.md

# Python caches
**/__pycache__
**/*.pyc
**/*.pyo
*.egg-info

# ML experiments / notebooks (not needed at runtime)
ml/experiments/
ml/README.md

# ML scripts (allow recommendation_v1.py via exception below)
ml/scripts/
!ml/scripts/recommendation_v1.py

# Raw / staging data (only artifacts are needed)
data/
data/raw/
data/eval/
data/features/
data/snapshots/
data/staging/
data/README.md

# Environment / IDE
.env
.vscode/
.idea/
*.swp
*.swo

# Large artifacts we don't need in Docker
ml/artifacts/*/embedding_similarity.npy
ml/artifacts/*/*.parquet
